# LPAM — backend / docker-compose configuration.
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).
#
# This file covers ONLY the gbrain Docker stack (backend + frontend).
# The Hermes agent has its own env at ~/.hermes/.env — see hermes-config/.env.example
# (added in a later phase) and docs/hermes-install.md.

# ── Ports / paths ───────────────────────────────────────────────────────────
BACKEND_PORT=3000              # host port mapped to the backend container
PORT=3000                      # port gbrain listens on inside the container
GBRAIN_BRAIN_DIR=./brain       # PGLite brain dir (relative to backend/); host-mounted at ./backend/brain
VAULT_DIR=./vault              # Obsidian vault mirrored into /app/vault (create it or point at your own)

# ── gbrain HTTP / MCP ───────────────────────────────────────────────────────
GBRAIN_HTTP_CORS_ORIGIN=*      # set to your frontend URL in production
# Shared secret the gbrain MCP endpoint requires (Authorization: Bearer …).
# Generate one: `openssl rand -hex 24`. The Hermes mcp_servers.gbrain block must use the SAME value.
MCP_GBRAIN_API_KEY=

# ── Embeddings (Ollama, OpenAI-compatible) ──────────────────────────────────
# 172.17.0.1 = the Docker bridge gateway → reaches a service on the VPS host.
# On a Mac+Tailscale topology, point these at the Mac's tailnet IP instead.
OLLAMA_HOST=http://172.17.0.1:11434
OLLAMA_BASE_URL=http://172.17.0.1:11434
OLLAMA_API_KEY=ollama          # Ollama ignores this; any non-empty value works
GBRAIN_EMBEDDING_MODEL=bge-m3
GBRAIN_EMBEDDING_DIMENSIONS=1024
GBRAIN_AI_EMBED_TIMEOUT_MS=60000

# ── Vector store (Qdrant on the VPS host) ───────────────────────────────────
QDRANT_HOST=http://172.17.0.1:6333

# ── Advanced / optional ─────────────────────────────────────────────────────
# The author's live VPS runs the backend via systemd on :3131 with the brain at
# /root/.gbrain/brain.pglite, and mounts a Plumbline CI checkout + a real vault.
# The compose defaults above (:3000, ./backend/brain) are the portable choice.
# To add the Plumbline read-only mount, uncomment its volume in docker-compose.yml.
