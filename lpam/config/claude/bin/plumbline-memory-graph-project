#!/bin/bash
# plumbline-memory-graph-project
# Wrapper script to run the Plumbline memory graph projector

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/../lib/plumbline_memory_graph_projection.py"

# Default data directory and output file
DATA_DIR="data"
OUTPUT_FILE="data/graph_projection/productive_graph.json"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --data-dir)
            DATA_DIR="$2"
            shift 2
            ;;
        --out|--output)
            OUTPUT_FILE="$2"
            shift 2
            ;;
        --json)
            JSON_FLAG="--json"
            shift
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

python3 "$PYTHON_SCRIPT" --data-dir "$DATA_DIR" --output "$OUTPUT_FILE" $JSON_FLAG