# Hermes agent env — copy to ~/.hermes/.env (or @@HERMES_HOME@@/.env). NEVER commit.
# Hermes interpolates ${VAR} references in config.yaml from this file.

# ── LLM (all via OpenRouter) ────────────────────────────────────────────────
OPENROUTER_API_KEY=            # sk-or-v1-...  (https://openrouter.ai/keys)

# ── gbrain long-term memory (MCP) ───────────────────────────────────────────
GBRAIN_MCP_URL=http://127.0.0.1:3131/mcp   # local: tunnel/loopback; must match config.yaml mcp_servers.gbrain.url
MCP_GBRAIN_API_KEY=            # SAME value as the gbrain backend's MCP key (see repo-root .env)

# ── Voice ───────────────────────────────────────────────────────────────────
VOICE_TOOLS_OPENAI_KEY=        # OpenAI key for gpt-4o-mini-tts (named to avoid clashing with OpenRouter)
GROQ_API_KEY=                  # Groq key for STT (whisper)

# ── Telegram gateway (optional) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=            # from @BotFather
TELEGRAM_ALLOWED_USERS=        # comma-separated numeric user ids allowed to talk to the bot
TELEGRAM_HOME_CHANNEL=         # your chat id (used by the model-health watcher to notify you)

# ── Paths ───────────────────────────────────────────────────────────────────
HERMES_HOME=                   # leave empty to default to ~/.hermes (hooks read this)
